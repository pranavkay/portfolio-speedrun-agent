# ── Portfolio Speedrun Agent — Environment Variables ──────────────────
#
# Copy this file to .env.local and fill in your values.
# Most of these are OPTIONAL — the site works out of the box with local storage.

# ── Site URL (for SEO and metadata) ──────────────────────────────────
# NEXT_PUBLIC_SITE_URL=https://yourdomain.com

# ── Google Analytics (optional) ──────────────────────────────────────
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ── Admin Panel Authentication ───────────────────────────────────────
# Required for the /admin panel to work
ADMIN_PASSWORD=change-me-to-a-strong-password
ADMIN_SECRET=change-me-to-a-random-string-at-least-32-chars

# ── Telemetry (opt-in, anonymous — helps us improve the project) ─────
# TELEMETRY_ENABLED=false
# NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ── Cloudflare R2 Storage (optional — only needed if storage: "r2") ──
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=portfolio-content
# R2_PUBLIC_URL=https://your-r2-domain.com
